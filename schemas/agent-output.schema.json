{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/intent-commerce-agent-output-1.0.json",
  "title": "Intent commerce agent analysis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "opportunityId",
    "merchantBrief",
    "recommendedAction",
    "campaignDraft",
    "evidenceRefs",
    "missingInformation",
    "risks",
    "confidence",
    "reviewRequired",
    "provenance"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "runId": { "type": "string", "minLength": 1 },
    "opportunityId": { "type": "string", "minLength": 1 },
    "merchantBrief": { "type": "string", "minLength": 40, "maxLength": 1200 },
    "recommendedAction": { "type": "string", "minLength": 30, "maxLength": 800 },
    "campaignDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "body", "channel"],
      "properties": {
        "subject": { "type": "string", "minLength": 5, "maxLength": 120 },
        "body": { "type": "string", "minLength": 20, "maxLength": 700 },
        "channel": { "enum": ["email", "sms"] }
      }
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "missingInformation": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
    "reviewRequired": { "type": "boolean", "const": true },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "agent", "createdAt", "inputHash", "promptVersion"],
      "properties": {
        "mode": { "type": "string", "const": "cli_agent" },
        "agent": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "inputHash": { "type": "string", "minLength": 8 },
        "promptVersion": { "type": "string", "const": "commerce-analyst-1.0" }
      }
    }
  }
}
